# 公開URL（OGP・構造化データの絶対URLに使う）。デプロイ後に本番ドメインを設定する。
NEXT_PUBLIC_SITE_URL=https://miyoki-labs.com

# GA4（任意）。設定すると計測タグが入る。
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Turnstile（任意・サイトキーはビルド時に使用）。
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=xxxxxxxxxxxxxxxxxxxx

# 以下は Cloudflare Pages Functions の環境変数として設定する（値はコミットしない）。
# TURNSTILE_SECRET_KEY=xxxxxxxxxxxxxxxxxxxx
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_TO_EMAIL=contact@example.com
# CONTACT_FROM_EMAIL=Miyoki Labs <contact@example.com>

# Slack通知（任意）。両方を設定した場合のみ有効。false または未設定なら no-op。
# SLACK_NOTIFICATIONS_ENABLED=false
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxxxxx/xxxxxxxx/xxxxxxxx
